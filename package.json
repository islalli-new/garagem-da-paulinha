{
  "name": "garagem-da-paulinha",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "firebase:login": "npx firebase-tools login",
    "firebase:use": "npx firebase-tools use garagem-da-paulinha",
    "firebase:rules": "npx firebase-tools deploy --only firestore:rules",
    "firebase:indexes": "npx firebase-tools deploy --only firestore:indexes",
    "firebase:emulators": "npx firebase-tools emulators:start --only firestore",
    "firebase:hosting": "npm run build && npx firebase-tools deploy --only hosting",
    "firebase:deploy": "npm run build && npx firebase-tools deploy --only hosting,firestore:rules,firestore:indexes"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.12.0",
    "lucide-react": "^1.7.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "firebase-tools": "^15.14.0",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
